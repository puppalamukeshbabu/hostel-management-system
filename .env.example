# Environment Variables for Hostel Management System
# Copy this to .env in backend folder for local development

# MongoDB connection string
# For local development:
# MONGODB_URI=mongodb://localhost:27017/hostel-ms
# 
# For MongoDB Atlas (cloud):
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hostel-ms?retryWrites=true&w=majority

# Server port
PORT=5001

# Node environment
NODE_ENV=development
